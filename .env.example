# ============================================================================
# PeriBook — Plantilla de variables de entorno
#
# Copia este archivo como .env en cada directorio de servicio y ajusta los
# valores según tu entorno. Los defaults (valores después de :-) permiten
# arrancar sin .env para desarrollo rápido.
#
# ⚠️  LOS ARCHIVOS .env NUNCA SE COMMITEAN (están en .gitignore).
# ============================================================================

# ── auth-service ─────────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=dev
# AUTH_DB_HOST=auth-db
# AUTH_DB_PORT=5432
# AUTH_DB_NAME=authdb
# AUTH_DB_USER=authuser
# AUTH_DB_PASSWORD=authpass
# JWT_RSA_PRIVATE_KEY_PATH=keys/jwt-private.pem
# JWT_RSA_PUBLIC_KEY_PATH=keys/jwt-public.pem

# ── user-service ─────────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=dev
# USER_DB_HOST=user-db
# USER_DB_PORT=5433
# USER_DB_NAME=userdb
# USER_DB_USER=useruser
# USER_DB_PASSWORD=userpass

# ── post-service ─────────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=dev
# POST_DB_HOST=post-db
# POST_DB_PORT=5434
# POST_DB_NAME=postdb
# POST_DB_USER=postuser
# POST_DB_PASSWORD=postpass
# RABBITMQ_HOST=peribook-rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest

# ── like-service ─────────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=dev
# LIKE_DB_HOST=like-db
# LIKE_DB_PORT=5435
# LIKE_DB_NAME=likedb
# LIKE_DB_USER=likeuser
# LIKE_DB_PASSWORD=likepass
# RABBITMQ_HOST=peribook-rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest

# ── realtime-service ─────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=dev
# RABBITMQ_HOST=peribook-rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest

# ── api-gateway ──────────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=dev
# CORS_ORIGINS=http://localhost:4200
# JWT_RSA_PUBLIC_KEY_PATH=keys/jwt-public.pem

# ── bff-web ──────────────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=dev

# ── frontend ─────────────────────────────────────────────────────────────────
# Sin variables de entorno (sirve contenido estático vía nginx)
