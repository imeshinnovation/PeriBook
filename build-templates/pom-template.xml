<?xml version="1.0" encoding="UTF-8"?>
<!--
  PLANTILLA — copiar dentro de cada microservicio nuevo como su pom.xml y
  ajustar los bloques marcados con «SERVICIO:». Ver ADR 0006 para el porqué
  de copiar en vez de heredar de un parent local.

  Bloques por tipo de servicio:
    - REST + JPA + Postgres  → auth-service, user-service, post-service, like-service
    - Mensajería (AMQP)      → post-service, like-service, realtime-service
    - Reactivo (WebFlux)     → api-gateway, bff-web
    - WebSocket              → realtime-service
  Elimina las dependencias que no apliquen a tu servicio; no las dejes "por si acaso".
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <!-- Se descarga de Maven Central por coordenadas — SIN relativePath.
       Esto es lo que permite que `docker build .` funcione con contexto
       limitado al propio directorio del servicio (ver ADR 0006). -->
  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>3.3.4</version>
    <relativePath/>
  </parent>

  <groupId>com.peribook</groupId>
  <!-- SERVICIO: reemplazar por auth-service / user-service / post-service / ... -->
  <artifactId>SERVICE_NAME</artifactId>
  <version>1.0.0</version>
  <name>SERVICE_NAME</name>
  <description>PeriBook — SERVICIO: descripción breve de una línea</description>

  <properties>
    <java.version>21</java.version>
    <maven.compiler.release>21</maven.compiler.release>
    <springdoc.version>2.6.0</springdoc.version>
    <mapstruct.version>1.6.2</mapstruct.version>
    <resilience4j.version>2.2.0</resilience4j.version>
    <testcontainers.version>1.20.1</testcontainers.version>
  </properties>

  <dependencies>

    <!-- ================= BASE — casi todos los servicios ================= -->

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
      <!-- SERVICIO: en api-gateway / bff-web, usar spring-boot-starter-webflux
           en vez de -web (son reactivos). No mezclar ambos en el mismo servicio. -->
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-validation</artifactId>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-actuator</artifactId>
    </dependency>

    <!-- Seguridad: valida el JWT emitido por auth-service (Resource Server).
         Va en TODOS los servicios detrás del Gateway, incluido auth-service
         para sus propios endpoints protegidos (no para /login, que es público). -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-oauth2-resource-server</artifactId>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-security</artifactId>
    </dependency>

    <!-- Documentación OpenAPI — SERVICIO: omitir en realtime-service
         (no expone contrato REST, solo WebSocket; ver plan sección 4.12). -->
    <dependency>
      <groupId>org.springdoc</groupId>
      <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
      <version>${springdoc.version}</version>
    </dependency>

    <!-- Mapeo DTO <-> Dominio -->
    <dependency>
      <groupId>org.mapstruct</groupId>
      <artifactId>mapstruct</artifactId>
      <version>${mapstruct.version}</version>
    </dependency>

    <!-- ================= PERSISTENCIA =================
         SERVICIO: solo auth-service, user-service, post-service, like-service.
         api-gateway, bff-web y realtime-service NO llevan este bloque
         (sin base de datos propia — ver ADR 0003 y plan sección 4.7). -->

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-data-jpa</artifactId>
    </dependency>
    <dependency>
      <groupId>org.postgresql</groupId>
      <artifactId>postgresql</artifactId>
      <scope>runtime</scope>
    </dependency>

    <!-- ================= MENSAJERÍA (RabbitMQ) =================
         SERVICIO: solo post-service, like-service (publishers) y
         realtime-service (consumer). auth-service y user-service NO la llevan. -->

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-amqp</artifactId>
    </dependency>

    <!-- ================= RESILIENCIA =================
         SERVICIO: principalmente bff-web (orquesta llamadas salientes) y
         api-gateway. Opcional en los demás. -->

    <dependency>
      <groupId>io.github.resilience4j</groupId>
      <artifactId>resilience4j-spring-boot3</artifactId>
      <version>${resilience4j.version}</version>
    </dependency>

    <!-- ================= WEBSOCKET =================
         SERVICIO: solo realtime-service. -->

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-websocket</artifactId>
    </dependency>

    <!-- ================= TESTING (TDD — ver ADR 0002) ================= -->

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.springframework.security</groupId>
      <artifactId>spring-security-test</artifactId>
      <scope>test</scope>
    </dependency>

    <!-- Testcontainers — solo servicios con Postgres y/o RabbitMQ propios
         (ver plan sección 4.10, pruebas de integración). -->
    <dependency>
      <groupId>org.testcontainers</groupId>
      <artifactId>junit-jupiter</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.testcontainers</groupId>
      <artifactId>postgresql</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.testcontainers</groupId>
      <artifactId>rabbitmq</artifactId>
      <scope>test</scope>
    </dependency>

  </dependencies>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>org.testcontainers</groupId>
        <artifactId>testcontainers-bom</artifactId>
        <version>${testcontainers.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <build>
    <plugins>
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <configuration>
          <release>${java.version}</release>
          <annotationProcessorPaths>
            <path>
              <groupId>org.mapstruct</groupId>
              <artifactId>mapstruct-processor</artifactId>
              <version>${mapstruct.version}</version>
            </path>
          </annotationProcessorPaths>
        </configuration>
      </plugin>
    </plugins>
  </build>

</project>
<!-- 2026-07-09 -->
